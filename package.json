{
  "name": "obsidian-hermes-sidebar",
  "version": "0.1.0",
  "description": "Hermes sidebar chat plugin for Obsidian",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "sync": "node scripts/sync-plugin.mjs",
    "build:sync": "npm run build && npm run sync",
    "reload": "obsidian plugin:reload id=hermes-sidebar",
    "deploy": "npm run build:sync && npm run reload"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.8.10",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3"
  }
}
